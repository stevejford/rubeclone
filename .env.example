# Database Configuration
# Neon PostgreSQL connection string
# Format: postgresql://username:password@hostname/database?sslmode=require
DATABASE_URL="postgresql://username:password@hostname/database?sslmode=require"

# NextAuth.js Configuration
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Your application URL (use http://localhost:3000 for development)
NEXTAUTH_URL="http://localhost:3000"

# Optional: OpenAI API Configuration (for AI features)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: Composio API Configuration (for tool integrations)
# Get your API key from https://app.composio.dev/
COMPOSIO_API_KEY="your-composio-api-key-here"
# OAuth callback URL for Composio integrations
# Development: http://localhost:3000/api/composio/callback
# Production: https://yourdomain.com/api/composio/callback
COMPOSIO_CALLBACK_URL="http://localhost:3000/api/composio/callback"
# Webhook secret for Composio webhooks (optional)
COMPOSIO_WEBHOOK_SECRET="your-composio-webhook-secret"
# Custom Composio API base URL (optional, defaults to official API)
COMPOSIO_BASE_URL="https://backend.composio.dev/api/v1"

# Application Environment
NODE_ENV="development"

# Optional: GitHub OAuth (for authentication)
# Create OAuth app at https://github.com/settings/applications/new
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Optional: Google OAuth (for authentication)
# Create OAuth credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: Stripe (for payments)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Optional: Redis (for caching and sessions)
# Option 1: Simple Redis URL (for local Redis)
REDIS_URL="redis://localhost:6379"

# Option 2: Redis Cloud Configuration (recommended for production)
# Get these from your Redis Cloud dashboard
REDIS_HOST="your-redis-host.redns.redis-cloud.com"
REDIS_PORT="15858"
REDIS_USERNAME="default"
REDIS_PASSWORD="your-redis-password"

# Optional: Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Optional: File Upload Configuration
# AWS S3 or compatible storage
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket-name"

# Composio Partner API Configuration
# Base URL for Composio Partner API (provides access to 750+ tools)
PARTNER_API_BASE_URL="https://mcp.composio.dev/api"
# Cache duration for marketplace data in seconds (default: 1 hour)
PARTNER_API_CACHE_TTL="3600"
# Default number of apps per page in marketplace (default: 24)
MARKETPLACE_PAGE_SIZE="24"
# Search debounce timing in milliseconds (default: 300ms)
MARKETPLACE_SEARCH_DEBOUNCE="300"
